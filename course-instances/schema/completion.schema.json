{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Completion Schema",
  "type": "object",
  "required": [
    "student_id",
    "course_code",
    "term",
    "completion_date",
    "final_grade",
    "credits_earned"
  ],
  "properties": {
    "student_id": {
      "type": "string"
    },
    "course_code": {
      "type": "string"
    },
    "term": {
      "type": "string"
    },
    "completion_date": {
      "type": "string",
      "format": "date"
    },
    "final_grade": {
      "type": "string"
    },
    "credits_earned": {
      "type": "number",
      "minimum": 0
    },
    "completion_status": {
      "type": "string",
      "enum": ["passed", "failed", "incomplete", "withdrawn"]
    }
  }
}