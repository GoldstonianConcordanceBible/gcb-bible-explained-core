{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Course Progress Schema",
  "type": "object",
  "required": [
    "student_id",
    "course_code",
    "playlist_completion",
    "videos_watched",
    "total_videos",
    "last_activity"
  ],
  "properties": {
    "student_id": {
      "type": "string"
    },
    "course_code": {
      "type": "string"
    },
    "playlist_completion": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "videos_watched": {
      "type": "integer",
      "minimum": 0
    },
    "total_videos": {
      "type": "integer",
      "minimum": 1
    },
    "last_activity": {
      "type": "string",
      "format": "date"
    },
    "notes": {
      "type": "string"
    }
  }
}